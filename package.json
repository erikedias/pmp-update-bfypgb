{
  "name": "painel-midia-paga",
  "productName": "Painel Midia Paga",
  "version": "1.3.21",
  "description": "Diagnostico semanal de gargalos de midia paga — Reportei + Trello + Gemini + Meta/Google Ads + GA4/GTM",
  "main": "electron/main.cjs",
  "author": "@diasesteci",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:macdir": "electron-builder --mac dir",
    "build:mac": "electron-builder --mac dmg zip",
    "build:win": "electron-builder --win nsis --x64",
    "dist": "electron-builder -mw"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.diasesteci.painelmidiapaga",
    "productName": "Painel Midia Paga",
    "afterPack": "build/afterPack.js",
    "asar": false,
    "npmRebuild": false,
    "files": [
      "electron/**",
      "src/**",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "identity": null,
      "extendInfo": {
        "CFBundleDisplayName": "Painel de Mídia Paga"
      }
    },
    "dmg": {
      "title": "Painel de Mídia Paga"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Painel de Mídia Paga"
    }
  }
}
